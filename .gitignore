data/

# ─── Secrets ─────────────────────────────────────────────────
# Match any local env file. Only `.env.example` and `.env*.example` are
# committed — those are templates with no real secrets.
.env
.env.*
!.env.example
!.env*.example
*.pem
*.key
secrets/

# ─── Editor / OS ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ─── Tooling caches ──────────────────────────────────────────
.claude/
.eslintcache
.turbo/
.cache/

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Misc ────────────────────────────────────────────────────
*.tgz
.vercel/
