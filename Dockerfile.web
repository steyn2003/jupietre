# syntax=docker/dockerfile:1.7

# ─── Stage 1: deps + build ─────────────────────────────────────────
FROM oven/bun:1.3-debian AS builder
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ git ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY tsconfig.json next.config.ts postcss.config.mjs drizzle.config.ts ./
COPY app ./app
COPY components ./components
COPY lib ./lib
COPY instrumentation.ts ./instrumentation.ts
COPY public ./public

ENV NEXT_TELEMETRY_DISABLED=1
RUN bun run build

# ─── Stage 2: runtime ──────────────────────────────────────────────
FROM oven/bun:1.3-debian AS runtime
WORKDIR /app

# Runtime tools:
#   git        → MCP git_* tools and worktree provisioning
#   make       → target repos commonly run `make build` / `make test`
#   nodejs/npm → @anthropic-ai/claude-code CLI (SDK spawns it as a subprocess)
#   tini       → proper signal handling
#   gosu       → entrypoint drops root → app after fixing volume ownership
#   python3 + pip → graphify (per-repo knowledge graph, exposed via MCP stdio)
#   curl + gnupg → gh apt-source setup (below)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git make ca-certificates tini gosu nodejs npm \
    curl gnupg \
    python3 python3-pip \
  && rm -rf /var/lib/apt/lists/*

# GitHub CLI (MCP gh_* tools)
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
  && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    > /etc/apt/sources.list.d/github-cli.list \
  && apt-get update && apt-get install -y --no-install-recommends gh \
  && rm -rf /var/lib/apt/lists/*

# Claude Code CLI — agent SDK spawns this as a subprocess
RUN npm install -g @anthropic-ai/claude-code

# graphify — tree-sitter extraction + MCP stdio server. Pulls prebuilt
# manylinux wheels on Debian (musl would have forced source compilation,
# which is why this image switched off Alpine).
RUN pip3 install --break-system-packages --no-cache-dir 'graphifyy[mcp]'

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Non-root user — Claude Code CLI refuses --dangerously-skip-permissions
# when running as root. Also creates writable dirs the agent needs.
RUN groupadd -r app \
  && useradd -r -g app -d /home/app -m -s /bin/bash app \
  && mkdir -p /app/data /home/app/.claude /home/app/.config \
  && chown -R app:app /app /home/app

# Allow git to operate on the data volume regardless of who cloned the repos
# (volumes can carry over ownership from previous container generations).
RUN su app -s /bin/bash -c "git config --global safe.directory '*'"

# Standalone output bundles only what the server needs.
COPY --from=builder --chown=app:app /app/.next/standalone ./
COPY --from=builder --chown=app:app /app/.next/static ./.next/static
COPY --from=builder --chown=app:app /app/public ./public
# Drizzle migration SQL — read at boot by lib/db/migrate.ts. Standalone build
# doesn't auto-include these because they're plain .sql files.
COPY --from=builder --chown=app:app /app/lib/db/migrations ./lib/db/migrations

# Platform skills — loaded by the Agent SDK via settingSources: ["user"] and
# available to every session regardless of which target repo it operates on.
COPY --chown=app:app skills/ /home/app/.claude/skills/

# Entrypoint runs as root, chowns the named volumes mounted on top of the
# image (otherwise stale ownership from earlier container generations
# breaks git operations against the cloned repos), then drops to `app`
# via gosu before exec'ing the server. Stays as root only for the
# milliseconds it takes to chown.
COPY --chmod=755 docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh

EXPOSE 3000
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["bun", "server.js"]
