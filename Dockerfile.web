# syntax=docker/dockerfile:1.7

# ─── Stage 1: deps + build ─────────────────────────────────────────
FROM oven/bun:1.3-alpine AS builder
WORKDIR /app

# Install build-time tools needed by some npm deps.
RUN apk add --no-cache python3 make g++ git

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY tsconfig.json next.config.ts postcss.config.mjs drizzle.config.ts ./
COPY app ./app
COPY components ./components
COPY lib ./lib
COPY instrumentation.ts ./instrumentation.ts
COPY public ./public

ENV NEXT_TELEMETRY_DISABLED=1
RUN bun run build

# ─── Stage 2: runtime ──────────────────────────────────────────────
FROM oven/bun:1.3-alpine AS runtime
WORKDIR /app

# Tools the runtime needs:
#   bash   → Claude Code's Bash tool literally invokes `bash`; Alpine ships
#            only `sh`, so without this every Bash tool call fails
#   coreutils → GNU versions of cat/ls/etc (Alpine's busybox versions miss
#            flags Claude/agents commonly use)
#   git    → MCP git_* tools and worktree provisioning
#   github-cli → MCP gh_* tools (run `gh auth login` once after first start)
#   make   → many target repos run `make build` / `make test`
#   ca-certificates → TLS for outbound API calls
#   tini   → proper signal handling
#   nodejs → @anthropic-ai/claude-code CLI (the agent SDK spawns it as a subprocess)
RUN apk add --no-cache \
  bash \
  coreutils \
  git \
  github-cli \
  make \
  ca-certificates \
  tini \
  nodejs \
  npm

# Install the Claude Code CLI so the agent SDK can spawn it.
RUN npm install -g @anthropic-ai/claude-code

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Non-root user — Claude Code CLI refuses --dangerously-skip-permissions
# when running as root. Also creates writable dirs the agent needs.
RUN addgroup -S app && adduser -S app -G app \
  && mkdir -p /app/data /home/app/.claude /home/app/.config \
  && chown -R app:app /app /home/app

# Allow git to operate on the data volume regardless of who cloned the repos
# (volumes can carry over ownership from previous container generations).
RUN su app -s /bin/sh -c "git config --global safe.directory '*'"

# Standalone output bundles only what the server needs.
COPY --from=builder --chown=app:app /app/.next/standalone ./
COPY --from=builder --chown=app:app /app/.next/static ./.next/static
COPY --from=builder --chown=app:app /app/public ./public
# Drizzle migration SQL — read at boot by lib/db/migrate.ts. Standalone build
# doesn't auto-include these because they're plain .sql files.
COPY --from=builder --chown=app:app /app/lib/db/migrations ./lib/db/migrations

# Platform skills — loaded by the Agent SDK via settingSources: ["user"] and
# available to every session regardless of which target repo it operates on.
COPY --chown=app:app skills/ /home/app/.claude/skills/

USER app

EXPOSE 3000
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["bun", "server.js"]
