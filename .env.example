# Authentication — pick ONE approach:

# Option A: Token pool (recommended — multiple tokens with auto-rotation)
# Comma-separated list of tokens. Agents rotate to the next token when one hits the threshold.
# CLAUDE_TOKENS=sk-ant-oat01-token1,sk-ant-oat01-token2,sk-ant-oat01-token3
# CLAUDE_TOKEN_TYPE=oauth                    # "oauth" (default) or "apikey"
# CLAUDE_TOKEN_DAILY_LIMIT_USD=50            # Per-token daily spend limit in USD (default: 50)
# CLAUDE_TOKEN_THRESHOLD=0.8                 # Switch to next token at this % of limit (default: 80%)

# Option B: Single token (legacy — falls back if CLAUDE_TOKENS is not set)
CLAUDE_CODE_OAUTH_TOKEN=
# Or: API key (pay-per-token billing)
ANTHROPIC_API_KEY=
LINEAR_API_KEY=
GITHUB_TOKEN=
GITHUB_REPO=owner/repo-name

# Multi-repo support (optional — comma-separated label:owner/repo pairs)
# When set, issues need a label matching one of these keys to route to the correct repo
# GITHUB_REPOS=app:owner/app-repo,api:owner/api-repo

POLL_INTERVAL_MS=120000
MAX_CONCURRENT=1

# Linear workflow state names (optional — override if your workspace uses different names)
STATUS_BACKLOG=Backlog
STATUS_IN_PROGRESS=In Progress
STATUS_IN_DEVELOPMENT=In Development
STATUS_IN_REVIEW=In Review
STATUS_DONE=Done
STATUS_WAITING=Waiting

# Role transitions (optional — override to rewire the pipeline)
# PM_PICKUP_STATE=Backlog
# PM_IN_PROGRESS_STATE=In Progress
# PM_DONE_STATE=In Development
# ENGINEER_PICKUP_STATE=In Development
# ENGINEER_IN_PROGRESS_STATE=In Development
# ENGINEER_DONE_STATE=In Review
# QA_PICKUP_STATE=In Review
# QA_IN_PROGRESS_STATE=In Review
# QA_DONE_STATE=Done

# Work schedule (optional — restrict when agents poll for work)
# WORK_SCHEDULE_START=08:00              # Start of work window (24h format)
# WORK_SCHEDULE_END=22:00                # End of work window
# WORK_SCHEDULE_DAYS=mon,tue,wed,thu,fri # Allowed days (default: all)
# WORK_SCHEDULE_TIMEZONE=Africa/Johannesburg  # Timezone (default: system local)

# Langfuse tracing (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
